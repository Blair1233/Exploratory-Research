def validate_email_domain(user: UserAccount, allowed_domains: List[str]) -> bool:
    """
    Check whether the user's email domain is in the list of allowed domains.
    """
    domain = user.email.split("@")[-1].lower()
    return domain in [d.lower() for d in allowed_domains]


def group_users_by_org(users: List[UserAccount]) -> Dict[str, List[UserAccount]]:
    """
    Group users by their organization.
    """
    groups: Dict[str, List[UserAccount]] = defaultdict(list)
    for user in users:
        groups[user.organization].append(user)
    return groups


def summarize_access(users: List[UserAccount]) -> Tuple[int, int]:
    """
    Return a tuple of (active_count, inactive_count).
    """
    active_count = sum(1 for u in users if u.active)
    inactive_count = len(users) - active_count
    return active_count, inactive_count


